# Supabase 공개 값 (앱 .env 와 동일 — dolbomdari/.env 참고)
NUXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
NUXT_PUBLIC_SUPABASE_ANON_KEY="sb_publishable_..."

# 서버 전용 — Supabase 대시보드 > Project Settings > API > service_role 키
NUXT_SUPABASE_SERVICE_ROLE_KEY=""

# 관리자 이메일 allowlist (쉼표로 구분)
NUXT_ADMIN_EMAILS="admin@example.com"
